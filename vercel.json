{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "admin/next.config.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/admin(.*)", "dest": "/admin$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
