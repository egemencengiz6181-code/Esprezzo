# ============================================================
#  ESPREZZO ADMIN — Environment Variables
#  Supabase Dashboard → Project Settings → API
#  Bu dosyayı kopyalayın → .env.local → gerçek değerleri girin
# ============================================================

# Supabase Project URL  (örn: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon / Public Key  (güvenli — RLS tarafından korunur)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase Service Role Key  (GIZLI — sadece migration scriptleri için)
# Supabase Dashboard → Project Settings → API → service_role
# ASLA commit etmeyin! .gitignore tarafından ignore edilir.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
