# ============================================================
#  ESPREZZO ADMIN — Environment Variables
#  Supabase Dashboard → Project Settings → API
#  Bu değerleri kopyalayıp gerçek değerlerle değiştirin.
# ============================================================

# Supabase Project URL  (örn: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon / Public Key  (güvenli — RLS tarafından korunur)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
